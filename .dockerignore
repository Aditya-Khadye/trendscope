# dbt local artifacts (dbt deps runs inside the image build)
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/ci.duckdb

# Not needed in the image
tests/
.github/
.claude/
Makefile
MIGRATION_PLAN.md
uv.lock
