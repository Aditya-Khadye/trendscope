# Copy to .env and fill in. .env is gitignored and also injected into the
# local Airflow containers by `astro dev start`.

# Enables the LLM narrative in the digest. Without it the digest still
# renders deterministically with a note.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Polygon API key for upgraded data / news (later phase).
# POLYGON_API_KEY=

# Optional overrides (defaults work for local dev):
# TRENDSCOPE_SETTINGS_PATH=config/settings.yaml
# TRENDSCOPE_PATHS__DUCKDB=data/trendscope.duckdb
# TRENDSCOPE_DUCKDB_PATH=data/trendscope.duckdb   # dbt profiles.yml
